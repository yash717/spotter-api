# .env.k8s — Local Kubernetes secrets for spotter-api
# Copy this file to .env.k8s and fill in real values.
# NEVER commit .env.k8s to git (it is in .gitignore).
# Reference: scripts/create-secrets.sh reads this file.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=spotter
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=spotter_k8s

# ── Django API ────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=changeme_generate_with_python_secrets_token_hex
INVITATION_JWT_SECRET=changeme_generate_with_python_secrets_token_hex_2
DB_PASSWORD=changeme_same_as_POSTGRES_PASSWORD

# ── SMTP (Brevo) ──────────────────────────────────────────────────────────────
SMTP_USER=your_brevo_smtp_user
SMTP_PASS=your_brevo_smtp_password
SMTP_FROM_EMAIL=noreply@yourdomain.com
EMAIL_FROM=noreply@yourdomain.com

# ── External APIs ─────────────────────────────────────────────────────────────
ORS_API_KEY=your_openrouteservice_api_key
