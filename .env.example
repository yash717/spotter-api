SECRET_KEY=django-insecure-dev-key-change-in-production-xk9$2m!
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# For production (Render): include API URL + frontend URL for CSRF (Django 4.0+)
# CSRF_TRUSTED_ORIGINS=https://spotter-api-ld45.onrender.com,https://spotter-ui-ashy.vercel.app
FRONTEND_URL=http://localhost:3000

# [F1] Separate invitation JWT secret — never reuse SECRET_KEY
INVITATION_JWT_SECRET=invitation-dev-secret-change-in-production-8f3k!m2

# Database (PostgreSQL; omit to use SQLite in dev)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/spotter_dev

# OpenRouteService
ORS_API_KEY=your-openrouteservice-api-key

# Email: Brevo API (recommended on Render - SMTP ports blocked on free tier)
# Get API key from Brevo: Settings → SMTP & API → API Keys
# BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxx

# Email (Brevo SMTP — for local dev or paid Render)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-user@smtp-brevo.com
# SMTP_PASS=your-brevo-smtp-key
# SMTP_FROM_EMAIL=noreply@yourdomain.com
# EMAIL_FROM=noreply@yourdomain.com
